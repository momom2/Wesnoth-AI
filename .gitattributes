# Files that MUST stay LF regardless of `core.autocrlf` on the
# checkout side. SLURM rejects sbatch scripts with CRLF
# ("Batch script contains DOS line breaks"); bash silently
# misbehaves on `set -e` scripts with CRLF (the trailing \r ends
# up in `$1` etc.); Lua / WML are the same story on the Wesnoth
# side. The Wesnoth simulator's WML parsing is byte-bit-exact, so
# stray CRs would diverge replay reconstruction.
*.sh           text eol=lf
*.sbatch       text eol=lf
*.bash         text eol=lf
*.lua          text eol=lf
*.cfg          text eol=lf

# Python: keep LF too. Native LF on disk avoids the "git diff
# shows the whole file changed because line endings flipped"
# trap when a Windows editor accidentally re-saves with CRLF.
*.py           text eol=lf

# JSON / Markdown: LF for the same diff-stability reason.
*.json         text eol=lf
*.md           text eol=lf

# PowerShell: native CRLF (Windows-only consumer; some PS5.1
# pipeline edge cases hiccup on LF here-strings).
*.ps1          text eol=crlf

# Binary checkpoints / replays / archives: don't even try.
*.pt           binary
*.bz2          binary
*.gz           binary
*.tar          binary
*.tar.gz       binary
*.png          binary
*.jpg          binary
