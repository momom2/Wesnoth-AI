# Auto-extracted Wesnoth save WML scaffolding for default-era 2p games.
# Source: tests/fixtures/strict_sync_hamlets_t9.bz2 (verified-loadable).
# Use tools/sim_to_replay.build_save_wml() to compose with a per-scenario
# [scenario] block + per-game [replay] block.
# ==== SECTION: prelude (top-level scalars) ====
abbrev=""
active_mods=""
campaign=""
campaign_define=""
campaign_extra_defines=""
campaign_name=""
campaign_type="multiplayer"
core="default"
difficulty="NORMAL"
end_credits="yes"
end_text=""
end_text_duration="0"
era_define=""
era_id="era_default"
label="%LABEL%"
mod_defines=""
mp_game_title="%LABEL%"
oos_debug="no"
random_mode=""
scenario_define=""
version="1.18.5"
# ==== SECTION: empty initial [replay] ====
[replay]
	[upload_log]
	[/upload_log]
[/replay]
# ==== SECTION: carryover_sides_start ====
[carryover_sides_start]

	next_scenario="%SCENARIO_ID%"
	random_calls=0
	random_seed="%RANDOM_SEED%"
	[variables]
	[/variables]
[/carryover_sides_start]
# ==== SECTION: multiplayer ====
