# Per-scenario [scenario] template for from-scratch save
# WML emission. Built from the game's own scenario .cfg by
# Wesnoth's own preprocessor (see
# tools/build_scenario_templates.py). [side] 1/2 stripped
# at build; the runtime emitter (sim_to_replay.build_save_wml)
# inserts fresh [side] blocks per game from sim state.
#
# Source: add-ons/wesnoth_ai drills (game cfg, game preprocessor)
# Regenerate via: python tools/build_scenario_templates.py
[scenario]
turns="-1"
experience_modifier="70"
has_mod_events="yes"
loaded_resources=""
objectives="<big>Victory:</big>\n<span color='#00ff00'>&#8226; Defeat enemy leader(s)</span>"
	description="wesnoth_ai capability drill: force or hold a one-hex mountain pass."
	id="drill_chokepoint"
	map_data="border_size=1
usage=map

Mm^Xm, Mm^Xm, Mm^Xm, Mm^Xm, Mm^Xm, Mm^Xm, Mm^Xm, Mm^Xm, Mm^Xm, Mm^Xm, Mm^Xm, Mm^Xm, Mm^Xm, Mm^Xm, Mm^Xm
Mm^Xm, Gg   , Gg   , Gg   , Gg   , Gg   , Gg   , Mm^Xm, Gg   , Gg   , Gg   , Gg   , Gg   , Gg   , Mm^Xm
Mm^Xm, Gg   , Gg   , Gg   , Gg   , Gg   , Gg^Vh, Mm^Xm, Gg^Vh, Gg   , Gg   , Gg   , Gg   , Gg   , Mm^Xm
Mm^Xm, Gg   , Ce   , Gg   , Gg   , Gg   , Gg   , Mm^Xm, Gg   , Gg   , Gg   , Gg   , Ce   , Gg   , Mm^Xm
Mm^Xm, Gg   , 1 Ke , Gg   , Gg   , Gg   , Gg   , Gg   , Gg   , Gg   , Gg   , Gg   , 2 Ke , Gg   , Mm^Xm
Mm^Xm, Gg   , Ce   , Gg   , Gg   , Gg   , Gg   , Mm^Xm, Gg   , Gg   , Gg   , Gg   , Ce   , Gg   , Mm^Xm
Mm^Xm, Gg   , Gg   , Gg   , Gg   , Gg   , Gg^Vh, Mm^Xm, Gg^Vh, Gg   , Gg   , Gg   , Gg   , Gg   , Mm^Xm
Mm^Xm, Gg   , Gg   , Gg   , Gg   , Gg   , Gg   , Mm^Xm, Gg   , Gg   , Gg   , Gg   , Gg   , Gg   , Mm^Xm
Mm^Xm, Mm^Xm, Mm^Xm, Mm^Xm, Mm^Xm, Mm^Xm, Mm^Xm, Mm^Xm, Mm^Xm, Mm^Xm, Mm^Xm, Mm^Xm, Mm^Xm, Mm^Xm, Mm^Xm
"
	name="Drill: Chokepoint"
