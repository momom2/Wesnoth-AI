# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtualenvs
.venv/
venv/
env/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~

# Project runtime artifacts (regenerated on each run)
logs/
training/profiles/
training/replays/
training/spool/

# Trained checkpoints + their learning-curve CSVs are deliberately
# TRACKED: months of training are not regenerable and the 2026-06
# machine loss proved local-only copies aren't safe. Keep the
# runtime stop-flag and job logs out.
training/checkpoints/done.flag
!training/logs/
training/logs/*
!training/logs/trainer_history_*.csv
add-ons/wesnoth_ai/games/
# Eval scenarios are generated, but the DIRECTORY must exist:
# _main.cfg's `{~add-ons/wesnoth_ai/scenarios/eval/}` include
# hard-errors the whole add-on when the dir is missing (observed
# 2026-06-12). Keep the .gitkeep tracked.
add-ons/wesnoth_ai/scenarios/eval/*
!add-ons/wesnoth_ai/scenarios/eval/.gitkeep

# Wesnoth debugging dumps (anywhere in the tree)
*.log

# Kaggle run artifacts pulled via `kaggle kernels output` (checkpoints,
# profile.json, run logs) — analyzed locally, not versioned.
kaggle/kaggle_output/

# External Wesnoth source — refreshed from the Steam install (see
# CLAUDE.md "Wesnoth data provenance"). Mostly untracked, EXCEPT the
# sim's runtime WML inputs (~840KB), tracked since 2026-07-02 so a
# bare clone can train on a rented GPU node without a Wesnoth
# install: factions (scenario_pool.load_factions hard-errors without
# them), 2p scenario .cfg (scenarios.py allowlist + scenario_events),
# .map files, and the Mini Maps add-on (--mini-ratio curriculum).
# gitignore can't re-include below an excluded dir, so un-exclude
# each level explicitly.
wesnoth_src/*
!wesnoth_src/data/
wesnoth_src/data/*
!wesnoth_src/data/multiplayer/
wesnoth_src/data/multiplayer/*
!wesnoth_src/data/multiplayer/factions/
!wesnoth_src/data/multiplayer/scenarios/
!wesnoth_src/data/multiplayer/maps/
!wesnoth_src/data/add-ons/
wesnoth_src/data/add-ons/*
!wesnoth_src/data/add-ons/Mini_Maps_Collection/

# Local data — corpus is too big for git; built by tools/download_replays.py
# and tools/replay_extract.py respectively.
replays_raw/
replays_dataset/
replays_dataset.old/
# Quarantined replays — produced by tools/purge_mod_replays.py for
# games that use plan_unit_advance (a 1.18-stock UI mod we'll
# eventually support). Restored if/when the sim learns the mechanic.
replays_raw_set_aside/
replays_dataset_set_aside/

# Pinned 1.18.4 scrape artifacts — deliberately TRACKED since
# 2026-06-12: the local 1.18.4 source they were scraped from is
# gone (wesnoth_src now mirrors the Steam install's NEWER data),
# so losing these would force a drifted re-scrape that breaks the
# sim's bit-exact combat pin. See CLAUDE.md "Wesnoth data
# provenance".
# (unit_stats.json and terrain_db.json intentionally not ignored)
tmp_scratch/
test_replays_temp/

# Tooling local config (Claude Code session metadata) -- but DO
# track the shared project settings + hooks (the recursive-delete
# safety guard lives there).
.claude/*
!.claude/settings.json
!.claude/hooks/

# per-run log artifacts (escrowed to HF, never tracked)
training/logs/trainer_history*.csv*
